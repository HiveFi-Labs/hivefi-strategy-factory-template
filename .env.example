# HiveFi 管理者から発行された 3 値のみを設定する。それ以外の URL / port / DB 名
# などは src/hivefi_factory/config.py に固定値として埋め込まれている。

# 1) Strategy API の認証キー
HIVEFI_API_KEY=hvf_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) ClickHouse Cloud (バックテスト結果と market data の直接読取) の per-tenant credentials
CLICKHOUSE_USER=u_xxxxxx
CLICKHOUSE_PASSWORD=xxxxxxxxxxxxxxxx
